# Supabase Configuration
# Get these values from your Supabase project dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App Configuration
# Set to http://localhost:3000 for local development
# Set to your production URL (e.g., https://the-ledger.vercel.app) for deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Polling interval for cross-device sync (in milliseconds)
# Default: 30000 (30 seconds)
# Lower values = faster sync but more network usage
NEXT_PUBLIC_POLL_INTERVAL_MS=5000
